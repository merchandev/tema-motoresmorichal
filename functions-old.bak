        'singular_name'      => 'VehĂ­culo',
        'add_new'            => 'AĂ±adir nuevo',
        'add_new_item'       => 'AĂ±adir vehĂ­culo',
        'edit_item'          => 'Editar vehĂ­culo',
        'new_item'           => 'Nuevo vehĂ­culo',
        'view_item'          => 'Ver vehĂ­culo',
        'search_items'       => 'Buscar vehĂ­culos',
        'not_found'          => 'No se encontraron vehĂ­culos',
        'not_found_in_trash' => 'No hay vehĂ­culos en la papelera',
        'menu_name'          => 'VehĂ­culos',
    );
    register_post_type('vehiculo', array(
        'labels' => $labels,
        'public' => true,
        'menu_position' => 22,
        'menu_icon' => 'dashicons-car',
        'supports' => array('title','editor','thumbnail'),
        'has_archive' => false,
        'rewrite' => array('slug' => 'vehiculo'),
        'show_in_rest' => true,
    ));

    // TaxonomĂ­a de categorĂ­as
    register_taxonomy('vehiculo_categoria', 'vehiculo', array(
        'label'        => 'CategorĂ­as de vehĂ­culo',
        'public'       => true,
        'hierarchical' => true,
        'rewrite'      => array('slug' => 'categoria-vehiculo'),
        'show_in_rest' => true,
    ));
});

