function toyota_m_datos_vehiculo($post){
    wp_nonce_field('vehiculo_meta_save','vehiculo_meta_nonce');
    $subtitulo = get_post_meta($post->ID, 'veh_subtitulo', true);
    $version   = get_post_meta($post->ID, 'veh_version', true);
    // $precio removed per new requirements
    $desc      = get_post_meta($post->ID, 'veh_desc', true);
    $ficha     = get_post_meta($post->ID, 'veh_ficha_url', true);
    $legal     = get_post_meta($post->ID, 'veh_legal_url', true);
    $colores   = get_post_meta($post->ID, 'veh_colores', true);
    if (!is_array($colores)){
        $decoded = json_decode((string)$colores, true);
        $colores = is_array($decoded) ? $decoded : array();
    }
    ?>
    <style>
      .veh-meta-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
      .veh-meta-grid label{display:block;font-weight:600;margin-bottom:6px}
      .veh-repeater .veh-row{display:grid;grid-template-columns:1.2fr 0.8fr 1fr 1fr auto;gap:10px;align-items:end;margin-bottom:10px}
      .veh-repeater input[type="text"], .veh-meta-grid input[type="text"]{width:100%}
      .veh-repeater .veh-color-preview{height:34px;border-radius:8px;border:1px solid #cbd5e1}
      .veh-repeater .button-link{color:#b91c1c}
    </style>
    <div class="veh-meta-grid">
      <div>
        <label for="veh_subtitulo">SubtĂ­tulo/Serie (ej: COROLLA CROSS 2025)</label>
        <input type="text" id="veh_subtitulo" name="veh_subtitulo" value="<?php echo esc_attr($subtitulo); ?>" />
      </div>
      <div>
        <label for="veh_version">VersiĂłn (ej: 2.0 CVT)</label>
        <input type="text" id="veh_version" name="veh_version" value="<?php echo esc_attr($version); ?>" />
      </div>
      
      <div>
        <label for="veh_ficha_url">URL ficha tĂ©cnica (opcional)</label>
        <input type="text" id="veh_ficha_url" name="veh_ficha_url" value="<?php echo esc_attr($ficha); ?>" />
      </div>
      <div>
        <label for="veh_legal_url">URL texto legal (opcional)</label>
        <input type="text" id="veh_legal_url" name="veh_legal_url" value="<?php echo esc_attr($legal); ?>" />
      </div>
      <div style="grid-column: 1 / -1;">
        <label for="veh_desc">Descripci&oacute;n corta (se muestra junto al bot&oacute;n de cotizar)</label>
        <textarea id="veh_desc" name="veh_desc" rows="3" style="width:100%;"><?php echo esc_textarea($desc); ?></textarea>
      </div>
    </div>

    <h4 style="margin:12px 0 6px;">Colores y fotos</h4>
    <p style="margin-top:0">AĂ±ade combinaciones de color (hex), nombre y las imĂˇgenes del auto para ese color (principal y hover opcional). Se usarĂˇn en el selector.</p>
    <div class="veh-repeater" id="veh_repeater">
      <?php if(!empty($colores)) foreach($colores as $i=>$row): ?>
      <div class="veh-row">
        <div>
          <label>Nombre del color</label>
          <input type="text" name="veh_colores[<?php echo $i; ?>][nombre]" value="<?php echo esc_attr($row['nombre'] ?? ''); ?>" />
        </div>
        <div>
          <label>Hex</label>
          <input type="text" name="veh_colores[<?php echo $i; ?>][hex]" value="<?php echo esc_attr($row['hex'] ?? ''); ?>" placeholder="#ffffff" />
        </div>
        <div>
          <label>Imagen principal (URL)</label>
          <input type="text" name="veh_colores[<?php echo $i; ?>][img]" value="<?php echo esc_url($row['img'] ?? ''); ?>" />
        </div>
        <div>
          <label>Imagen hover (URL)</label>
          <input type="text" name="veh_colores[<?php echo $i; ?>][img2]" value="<?php echo esc_url($row['img2'] ?? ''); ?>" />
        </div>
        <div>
          <div class="veh-color-preview" style="background:<?php echo esc_attr($row['hex'] ?? '#ccc'); ?>"></div>
          <a href="#" class="button-link veh-del">Eliminar</a>
        </div>
      </div>
      <?php endforeach; ?>
    </div>
    <p><button type="button" class="button button-primary veh-add">Agregar color</button></p>
    <template id="veh_row_tpl">
      <div class="veh-row">
        <div>
          <label>Nombre del color</label>
          <input type="text" name="veh_colores[__i__][nombre]" value="" />
        </div>
        <div>
          <label>Hex</label>
          <input type="text" name="veh_colores[__i__][hex]" value="#ffffff" placeholder="#ffffff" />
        </div>
        <div>
          <label>Imagen principal (URL)</label>
          <input type="text" name="veh_colores[__i__][img]" value="" />
        </div>
        <div>
          <label>Imagen hover (URL)</label>
          <input type="text" name="veh_colores[__i__][img2]" value="" />
        </div>
        <div>
          <div class="veh-color-preview" style="background:#ffffff"></div>
          <a href="#" class="button-link veh-del">Eliminar</a>
        </div>
      </div>
    </template>
    <?php
}

// Guardar metacampos
add_action('save_post_vehiculo', function($post_id){
    if (!isset($_POST['vehiculo_meta_nonce']) || !wp_verify_nonce($_POST['vehiculo_meta_nonce'], 'vehiculo_meta_save')) return;
    if (defined('DOING_AUTOSAVE') && DOING_AUTOSAVE) return;
    if (!current_user_can('edit_post', $post_id)) return;
    $fields = array('veh_subtitulo','veh_version','veh_desc','veh_ficha_url','veh_legal_url');
    foreach($fields as $f){ if (isset($_POST[$f])) update_post_meta($post_id, $f, sanitize_text_field($_POST[$f])); }
    // Colores
    if (isset($_POST['veh_colores']) && is_array($_POST['veh_colores'])){
        $clean = array();
        foreach($_POST['veh_colores'] as $row){
            if (empty($row['img']) && empty($row['nombre'])) continue;
            $clean[] = array(
                'nombre' => sanitize_text_field($row['nombre'] ?? ''),
                'hex'    => sanitize_text_field($row['hex'] ?? ''),
                'img'    => esc_url_raw($row['img'] ?? ''),
                'img2'   => esc_url_raw($row['img2'] ?? ''),
            );
        }
        update_post_meta($post_id, 'veh_colores', $clean);
    } else {
        delete_post_meta($post_id, 'veh_colores');
    }
});

// Admin: media uploader y color picker para CPT Vehículos
add_action('admin_enqueue_scripts', function($hook){
    global $typenow;
    if ($typenow === 'vehiculo') {
        wp_enqueue_media();
        wp_enqueue_style('wp-color-picker');
        wp_enqueue_script('wp-color-picker');
        add_action('admin_print_footer_scripts', function(){ ?>
<script>
(function($){
  function enhance($ctx){
    // Color picker en campos [hex]
    $ctx.find('input[name*="[hex]"]').not('.veh-has-color').each(function(){
      var $inp = $(this).addClass('veh-has-color');
      if (typeof $.fn.wpColorPicker === 'function') {
        $inp.wpColorPicker({
          change: function(event, ui){
            var $row = $(event.target).closest('.veh-row');
            $row.find('.veh-color-preview').css('background', ui.color.toString());
          }
        });
      }
    });
    // Botón de seleccionar imagen al lado de inputs [img] y [img2]
    $ctx.find('input[name*="[img]"]').each(function(){
      var $inp = $(this);
      if ($inp.data('veh-media-added')) return;
      $inp.data('veh-media-added', true);
      var $btn = $('<button type="button" class="button veh-media-insert" style="margin-left:6px;">Seleccionar…</button>').insertAfter($inp);
      $btn.on('click', function(e){
        e.preventDefault();
        var frame = wp.media({ title: 'Seleccionar imagen', multiple: false, library: { type: 'image' } });
        frame.on('select', function(){ var file = frame.state().get('selection').first().toJSON(); $inp.val(file.url); });
        frame.open();
      });
    });
  }
  $(function(){
    enhance($(document));
    var rep = document.getElementById('veh_repeater');
    if (rep) {
      var obs = new MutationObserver(function(){ enhance($(document)); });
      obs.observe(rep, { childList: true, subtree: true });
    }
    // Add & remove rows for colors
    $(document).on('click', '.veh-add', function(e){
      e.preventDefault();
      var tpl = document.getElementById('veh_row_tpl');
      if (!tpl) return;
      var next = (function(){
        var i = 0; $(rep).find('.veh-row').each(function(){
          var name = $(this).find('input[name^="veh_colores["]').first().attr('name')||'';
          var m = name.match(/^veh_colores\[(\d+)/); if(m){ i = Math.max(i, parseInt(m[1])+1); }
        });
        return i;
      })();
      var html = tpl.innerHTML.replace(/__i__/g, next);
      $(rep).append(html);
    });
    $(document).on('click', '.veh-del', function(e){
      e.preventDefault();
      $(this).closest('.veh-row').remove();
    });
  });
})(jQuery);
</script>
<?php });
    }
});

// Corrige etiquetas mal codificadas (UTF-8) para el CPT y la taxonomía
add_action('init', function(){
    global $wp_post_types, $wp_taxonomies;
    if (isset($wp_post_types['vehiculo'])) {
        $l = $wp_post_types['vehiculo']->labels;
        $l->name = 'Vehículos';
        $l->singular_name = 'Vehículo';
        $l->add_new = 'Ańadir nuevo';
        $l->add_new_item = 'Ańadir vehículo';
        $l->edit_item = 'Editar vehículo';
        $l->new_item = 'Nuevo vehículo';
        $l->view_item = 'Ver vehículo';
        $l->search_items = 'Buscar vehículos';
        $l->not_found = 'No se encontraron vehículos';
        $l->not_found_in_trash = 'No hay vehículos en la papelera';
        $l->menu_name = 'Vehículos';
    }
    if (isset($wp_taxonomies['vehiculo_categoria'])) {
        $t = $wp_taxonomies['vehiculo_categoria'];
        $t->labels->name = 'Categorías de vehículo';
        $t->labels->singular_name = 'Categoría de vehículo';
    }
}, 20);

// Forzar plantilla para la pĂˇgina VehĂ­culos si existe
add_filter('template_include', function($template){
    if (is_page('vehiculos')) {
        $t = locate_template('vehiculos.php');
        if ($t) return $t;
    }
    return $template;
}, 20);

// Forzar plantilla para la página Sobre Nosotros si existe
add_filter('template_include', function($template){
    if (is_page('sobre-nosotros')) {
        $t = locate_template('sobre-nosotros.php');
        if ($t) return $t;
    }
    return $template;
}, 20);



